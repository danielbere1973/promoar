generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("trusted_devices")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum CardType {
  CREDIT
  DEBIT
  PREPAID
  ACCOUNT
}

enum DiscountType {
  PERCENTAGE_REINTEGRO
  PERCENTAGE_DESCUENTO
  BONIFICACION
  FIXED_AMOUNT
  NXM
  CUOTAS_SIN_INTERES
}

enum CapPeriod {
  PER_TRANSACTION
  DAILY
  WEEKLY
  MONTHLY
  TOTAL
}

enum CapTarget {
  USER
  CARD
  ACCOUNT
  TRANSACCION
}

enum PromoStatus {
  DRAFT
  ACTIVE
  EXPIRED
  PAUSED
}

enum PaymentChannel {
  ANY
  QR
  NFC
  TARJETA_FISICA
  TRANSFERENCIA
  DINERO_EN_CUENTA
}

enum AccountType {
  ANY
  HABERES
  JUBILADO
  ANSES
}

enum PostType {
  AVIVADA
  PROMO
  ERROR_PRECIO
  COMBO
  CONSULTA
}

enum FinanceItemType {
  PLAZO_FIJO
  CAUCION
  LECAP
  LECER
  BOPREAL
  ON
  FCI_MM
  DOLAR_TIPO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  verificationCode String?
  codeExpires      DateTime?
  role          Role      @default(USER)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Datos Personales
  lastName      String?
  phoneMobile   String?
  phoneFixed    String?
  documentType  String?
  documentNumber String?
  
  // Domicilio
  addressStreet   String?
  addressNumber   String?
  addressFloor    String?
  addressApt      String?
  addressZipCode  String?
  addressCity     String?
  addressState    String?
  addressCountry  String?

  accounts      Account[]
  sessions      Session[]
  financialProfile FinancialProfile?
  posts         CommunityPost[]
  postLikes     PostLike[]
  promoReports  PromoReport[]
  savedPromos   SavedPromo[]
  trustedDevices TrustedDevice[]
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model FinancialProfile {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  banks     UserBank[]
  wallets   UserWallet[]
  cards     UserCard[]
  updatedAt DateTime   @updatedAt
  @@map("financial_profiles")
}

model UserBank {
  id                 String           @id @default(cuid())
  financialProfileId String
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  bankId             String
  bank               Bank             @relation(fields: [bankId], references: [id])
  createdAt          DateTime         @default(now())
  @@unique([financialProfileId, bankId])
  @@map("user_banks")
}

model UserWallet {
  id                 String           @id @default(cuid())
  financialProfileId String
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  walletId           String
  wallet             Wallet           @relation(fields: [walletId], references: [id])
  createdAt          DateTime         @default(now())
  @@unique([financialProfileId, walletId])
  @@map("user_wallets")
}

model UserCard {
  id                 String           @id @default(cuid())
  financialProfileId String
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  bankId             String?
  bank               Bank?            @relation(fields: [bankId], references: [id])
  cardNetworkId      String?
  cardNetwork        CardNetwork?     @relation(fields: [cardNetworkId], references: [id])
  cardType           CardType
  isVirtual          Boolean          @default(false)
  walletId           String?
  wallet             Wallet?          @relation(fields: [walletId], references: [id])
  label              String?
  segment            String?    // Deprecated: usar segmentId
  segmentId          String?
  segmentRef         BankSegment? @relation(fields: [segmentId], references: [id])
  lastFour           String?
  createdAt          DateTime         @default(now())
  accountNumber      String?    //CBU (banco+cuenta) o CVU (billetera)
  shortAccountNumber String?    // El número de cuenta corto
  bankAccountType    String?    // CA (Caja de Ahorros) o CC (Cuenta Corriente)
  currency           String?    // ARS o USD
  alias              String?    // Alias de CBU o CVU
  isPayroll          Boolean    @default(false)
  isPensioner        Boolean    @default(false)
  @@map("user_cards")
}

model BankSegment {
  id        String   @id @default(cuid())
  name      String
  bankId    String
  bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  
  userCards UserCard[]
  promoRequirements PromoRequirement[]

  @@unique([bankId, name])
  @@map("bank_segments")
}

model Bank {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  logoUrl   String?
  active    Boolean    @default(true)
  userBanks UserBank[]
  userCards UserCard[]
  segments  BankSegment[]
  cardNetworks CardNetwork[]
  promoRequirements PromoRequirement[]
  @@map("banks")
}

model Wallet {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  logoUrl     String?
  active      Boolean      @default(true)
  userWallets UserWallet[]
  userCards   UserCard[]
  promoRequirements PromoRequirement[]
  @@map("wallets")
}

model CardNetwork {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  banks     Bank[]
  userCards UserCard[]
  promoRequirements PromoRequirement[]
  @@map("card_networks")
}

model Category {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  icon   String
  color  String
  order  Int     @default(0)
  promos Promo[]
  @@map("categories")
}

model Commerce {
  id      String  @id @default(cuid())
  name    String  @unique
  slug    String  @unique
  logoUrl String?
  website String?
  active  Boolean @default(true)
  promos  Promo[]
  @@map("commerces")
}

model Promo {
  id            String       @id @default(cuid())
  title         String
  description   String       @db.Text
  uniqueUsePerPeriod Boolean @default(false)
  maxUsesPerPeriod   Int?
  stackable          Boolean @default(false)
  stackableNote      String?
  validFrom     DateTime
  validUntil    DateTime?
  validDays     Int          @default(127)
  validDaysNote String?
  validFromHour Int?
  validToHour   Int?
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  commerceId    String
  commerce      Commerce     @relation(fields: [commerceId], references: [id])
  requirements  PromoRequirement[]
  status        PromoStatus  @default(DRAFT)
  sourceUrl     String?
  sourceNote    String?
  sourceText    String?      @db.Text
  specificDates String?      @db.Text
  provinces     String[]     @default([])
  verifiedAt    DateTime?
  userReports   PromoReport[]
  savedByUsers  SavedPromo[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@index([categoryId])
  @@index([commerceId])
  @@index([status])
  @@index([validUntil])
  @@map("promos")
}

model PromoRequirement {
  id             String         @id @default(cuid())
  promoId        String
  promo          Promo          @relation(fields: [promoId], references: [id], onDelete: Cascade)
  bankId         String?
  bank           Bank?          @relation(fields: [bankId], references: [id])
  walletId       String?
  wallet         Wallet?        @relation(fields: [walletId], references: [id])
  cardNetworkId  String?
  cardNetwork    CardNetwork?   @relation(fields: [cardNetworkId], references: [id])
  cardType       CardType?
  paymentChannel PaymentChannel @default(ANY)
  accountType    AccountType    @default(ANY)
  accountTypeRef FinancialAccountType? @relation(fields: [accountTypeId], references: [id])
  accountTypeId  String?
  segment        String?        // Deprecated: usar segmentId
  segmentId      String?
  segmentRef     BankSegment?   @relation(fields: [segmentId], references: [id])

  discountType   DiscountType   @default(PERCENTAGE_REINTEGRO)
  discountValue  Float          @default(0)
  nxmN           Int?
  nxmM           Int?
  minPurchase    Float?
  cap            Float?
  capPeriod      CapPeriod?
  capTarget      CapTarget?    @default(USER)
  
  note           String?
  @@map("promo_requirements")
}

model CommunityPost {
  id        String    @id @default(cuid())
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type      PostType
  body      String    @db.Text
  commerce  String?
  location  String?
  status    String    @default("active")
  likes     Int       @default(0)
  userLikes PostLike[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@index([type])
  @@index([createdAt])
  @@map("community_posts")
}

model PostLike {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  @@unique([postId, userId])
  @@map("post_likes")
}

model PromoReport {
  id        String   @id @default(cuid())
  promoId   String
  promo     Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())
  @@unique([promoId, userId])
  @@map("promo_reports")
}

model FinanceItem {
  id           String          @id @default(cuid())
  type         FinanceItemType
  entityName   String
  code         String?
  rateTNA      Float?
  rateTEA      Float?
  rateTEM      Float?
  rateAdjust   String?
  term         Int?
  maturityDate DateTime?
  auctionDate  DateTime?
  currency     String          @default("ARS")
  notes        String?         @db.Text
  sourceUrl    String?
  active       Boolean         @default(true)
  updatedAt    DateTime        @updatedAt
  createdAt    DateTime        @default(now())
  @@index([type])
  @@index([active])
  @@map("finance_items")
}

model SavedPromo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoId   String
  promo     Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, promoId])
  @@map("saved_promos")
}

model Currency {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique // ARS, USD, etc.
  symbol    String?  // $, U$S, etc.
  createdAt DateTime @default(now())
  @@map("currencies")
}

model FinancialAccountType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  promoRequirements PromoRequirement[]
  @@map("financial_account_types")
}