generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECTURL")
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trusted_devices")
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role              @default(USER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  codeExpires      DateTime?
  verificationCode String?
  addressApt       String?
  addressCity      String?
  addressCountry   String?
  addressFloor     String?
  addressNumber    String?
  addressState     String?
  addressStreet    String?
  addressZipCode   String?
  documentNumber   String?
  documentType     String?
  lastName         String?
  phoneFixed       String?
  phoneMobile      String?
  active           Boolean           @default(true)
  accounts         Account[]
  posts            CommunityPost[]
  financialProfile FinancialProfile?
  postLikes        PostLike[]
  promoReports     PromoReport[]
  savedPromos      SavedPromo[]
  sessions         Session[]
  trustedDevices   TrustedDevice[]
  events           UserEvent[]
  pushSubscriptions        PushSubscription[]
  notificationPreferences  NotificationPreference[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  id             String     @id @default(cuid())
  userId         String
  type           NotifType

  // Objetivo: categoría y/o comercio específico
  categoryId     String?
  commerceId     String?

  // Condiciones de entidad financiera
  bankId         String?
  walletId       String?
  cardNetworkId  String?
  cardSegmentId  String?

  // Condiciones de beneficio
  minDiscount    Int?
  discountFilter String     @default("ALL")   // ALL | DISCOUNT_ONLY | CSI_ONLY

  // Periodicidad y vigencia
  maxPerWeek     Int        @default(3)
  sentThisWeek   Int        @default(0)
  weekStartedAt  DateTime?
  lastSentAt     DateTime?
  active         Boolean    @default(true)
  validUntil     DateTime?
  createdAt      DateTime   @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id])
  commerce      Commerce?     @relation(fields: [commerceId], references: [id])
  bank          Bank?         @relation(fields: [bankId], references: [id])
  wallet        Wallet?       @relation(fields: [walletId], references: [id])
  cardNetwork   CardNetwork?  @relation(fields: [cardNetworkId], references: [id])
  cardSegment   BankSegment?  @relation(fields: [cardSegmentId], references: [id])

  @@index([userId, active])
  @@map("notification_preferences")
}

model UserEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String
  eventType  String
  payload    Json
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([eventType])
  @@index([createdAt])
  @@map("user_events")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model FinancialProfile {
  id        String       @id @default(cuid())
  userId    String       @unique
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  banks     UserBank[]
  cards     UserCard[]
  wallets   UserWallet[]

  @@map("financial_profiles")
}

model UserBank {
  id                 String           @id @default(cuid())
  financialProfileId String
  bankId             String
  createdAt          DateTime         @default(now())
  bank               Bank             @relation(fields: [bankId], references: [id])
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)

  @@unique([financialProfileId, bankId])
  @@map("user_banks")
}

model UserWallet {
  id                 String           @id @default(cuid())
  financialProfileId String
  walletId           String
  createdAt          DateTime         @default(now())
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  wallet             Wallet           @relation(fields: [walletId], references: [id])

  @@unique([financialProfileId, walletId])
  @@map("user_wallets")
}

model UserCard {
  id                 String           @id @default(cuid())
  financialProfileId String
  bankId             String?
  cardNetworkId      String?
  cardType           CardType
  cardTier           CardTier?
  cardSegmentId      String?
  isVirtual          Boolean          @default(false)
  walletId           String?
  label              String?
  createdAt          DateTime         @default(now())
  lastFour           String?
  segment            String?
  segmentId          String?
  accountNumber      String?
  bankAccountType    String?
  currency           String?
  shortAccountNumber String?
  alias              String?
  isPayroll          Boolean          @default(false)
  isPensioner        Boolean          @default(false)
  bank               Bank?            @relation(fields: [bankId], references: [id])
  cardNetwork        CardNetwork?     @relation(fields: [cardNetworkId], references: [id])
  cardSegmentRef     CardSegment?     @relation(fields: [cardSegmentId], references: [id])
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  segmentRef         BankSegment?     @relation(fields: [segmentId], references: [id])
  wallet             Wallet?          @relation(fields: [walletId], references: [id])

  @@map("user_cards")
}

model BankSegment {
  id                String             @id @default(cuid())
  name              String
  bankId            String
  bank              Bank               @relation(fields: [bankId], references: [id], onDelete: Cascade)
  promoRequirements PromoRequirement[]
  userCards         UserCard[]
  notifPreferences  NotificationPreference[]

  @@unique([bankId, name])
  @@map("bank_segments")
}

model Bank {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  logoUrl           String?
  active            Boolean            @default(true)
  bcraCode          String?            @unique
  codigoModo        String?
  bank_modo_codes   bank_modo_codes[]
  segments          BankSegment[]
  promoRequirements PromoRequirement[]
  userBanks         UserBank[]
  userCards         UserCard[]
  cardNetworks      CardNetwork[]      @relation("BankToCardNetwork")
  cardSegments      CardSegment[]      @relation("BankToCardSegment")
  notifPreferences  NotificationPreference[]

  @@index([codigoModo], map: "banks_codigo_modo_idx")
  @@map("banks")
}

model Wallet {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  logoUrl           String?
  active            Boolean            @default(true)
  promoRequirements PromoRequirement[]
  userCards         UserCard[]
  userWallets       UserWallet[]
  cardNetworks      CardNetwork[]      @relation("WalletToCardNetwork")
  cardSegments      CardSegment[]      @relation("WalletToCardSegment")
  notifPreferences  NotificationPreference[]

  @@map("wallets")
}

model CardNetwork {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  promoRequirements PromoRequirement[]
  userCards         UserCard[]
  banks             Bank[]             @relation("BankToCardNetwork")
  cardSegments      CardSegment[]
  wallets           Wallet[]           @relation("WalletToCardNetwork")
  notifPreferences  NotificationPreference[]

  @@map("card_networks")
}

model CardSegment {
  id                String             @id @default(cuid())
  cardNetworkId     String
  cardType          CardType
  name              String
  cardNetwork       CardNetwork        @relation(fields: [cardNetworkId], references: [id], onDelete: Cascade)
  promoRequirements PromoRequirement[]
  userCards         UserCard[]
  banks             Bank[]             @relation("BankToCardSegment")
  wallets           Wallet[]           @relation("WalletToCardSegment")

  @@unique([cardNetworkId, cardType, name])
  @@map("card_segments")
}

model Category {
  id               String     @id @default(cuid())
  name             String     @unique
  slug             String     @unique
  icon             String
  color            String
  order            Int        @default(0)
  promos                   Promo[]
  defaultCommerce          Commerce[]               @relation("CommerceDefaultCategory")
  notificationPreferences  NotificationPreference[]

  @@map("categories")
}

model Commerce {
  id                String           @id @default(cuid())
  name              String           @unique
  slug              String           @unique
  logoUrl           String?
  website           String?
  instagramUrl      String?
  active            Boolean          @default(true)
  defaultCategoryId String?
  activePromoCount  Int              @default(0)
  defaultCategory   Category?        @relation("CommerceDefaultCategory", fields: [defaultCategoryId], references: [id])
  promos                   Promo[]
  branches                 CommerceBranch[]
  products                 CommerceProduct[]
  aliases                  CommerceAlias[]
  notificationPreferences  NotificationPreference[]

  @@map("commerces")
}

model CommerceAlias {
  id         String   @id @default(cuid())
  alias      String   @unique
  commerceId String
  commerce   Commerce @relation(fields: [commerceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("commerce_aliases")
}

// Catálogo de categorías/productos que vende cada comercio (scrapeado de su sitio online).
// Permite búsqueda "¿qué comercios venden carteras?" sin modelar precios (ver punto 9 de CLAUDE.md).
model CommerceProduct {
  id           String   @id @default(cuid())
  commerceId   String
  commerce     Commerce @relation(fields: [commerceId], references: [id], onDelete: Cascade)
  categoria    String
  subcategoria String?
  productos    String?
  source       String   @default("unicenter")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([commerceId])
  @@index([categoria])
  @@map("commerce_products")
}

model CommerceBranch {
  id         String   @id @default(cuid())
  commerceId String
  commerce   Commerce @relation(fields: [commerceId], references: [id], onDelete: Cascade)
  name       String?
  address    String?
  city       String?
  province   String?
  lat        Float
  lng        Float
  source     String   @default("OSM")
  osmId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([source, osmId])
  @@index([commerceId])
  @@index([lat, lng])
  @@map("commerce_branches")
}

model Promo {
  id                 String             @id @default(cuid())
  title              String
  description        String
  uniqueUsePerPeriod Boolean            @default(false)
  maxUsesPerPeriod   Int?
  stackable          Boolean            @default(false)
  stackableNote      String?
  validFrom          DateTime
  validUntil         DateTime?
  validDays          Int                @default(127)
  validDaysNote      String?
  validFromHour      Int?
  validToHour        Int?
  categoryId         String
  commerceId         String
  status             PromoStatus        @default(DRAFT)
  isFeatured         Boolean            @default(false)
  maxDiscountPct     Int?
  isCSIOnly          Boolean            @default(false)
  sourceUrl          String?
  sourceNote         String?
  commerceNote       String?            // Ej: "Solo comercios con Openpay"
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sourceText         String?
  specificDates      String?
  salesChannel       String?
  provinces          String[]           @default([])
  slug               String?            @unique
  userReports        PromoReport[]
  requirements       PromoRequirement[]
  category           Category           @relation(fields: [categoryId], references: [id])
  commerce           Commerce           @relation(fields: [commerceId], references: [id])
  savedByUsers       SavedPromo[]

  @@index([categoryId])
  @@index([commerceId])
  @@index([status])
  @@index([validUntil])
  @@index([status, isCSIOnly, maxDiscountPct(sort: Desc)])
  @@map("promos")
}

model PromoRequirement {
  id              String                @id @default(cuid())
  promoId         String
  bankId          String?
  walletId        String?
  cardNetworkId   String?
  cardType        CardType?
  cardTier        CardTier?
  cardSegmentId   String?
  note            String?
  accountType     AccountType           @default(ANY)
  paymentChannel  PaymentChannel        @default(ANY)
  cap             Float?
  capUnlimited    Boolean               @default(false)
  capPeriod       CapPeriod?
  discountType    DiscountType          @default(PERCENTAGE_REINTEGRO)
  discountValue   Float                 @default(0)
  minPurchase     Float?
  nxmM            Int?
  nxmN            Int?
  segment         String?
  segmentId       String?
  accountTypeId   String?
  capTarget       CapTarget?            @default(USER)
  accountTypeRef  FinancialAccountType? @relation(fields: [accountTypeId], references: [id])
  bank            Bank?                 @relation(fields: [bankId], references: [id])
  cardNetwork     CardNetwork?          @relation(fields: [cardNetworkId], references: [id])
  cardSegmentRef  CardSegment?          @relation(fields: [cardSegmentId], references: [id])
  promo           Promo                 @relation(fields: [promoId], references: [id], onDelete: Cascade)
  segmentRef      BankSegment?          @relation(fields: [segmentId], references: [id])
  wallet          Wallet?               @relation(fields: [walletId], references: [id])

  @@map("promo_requirements")
}

model CommunityPost {
  id        String     @id @default(cuid())
  authorId  String
  type      PostType
  body      String
  commerce  String?
  location  String?
  status    String     @default("active")
  likes     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  userLikes PostLike[]

  @@index([type])
  @@index([createdAt])
  @@map("community_posts")
}

model PostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model PromoReport {
  id        String   @id @default(cuid())
  promoId   String
  userId    String
  reason    String?
  createdAt DateTime @default(now())
  promo     Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoId, userId])
  @@map("promo_reports")
}

model FinanceItem {
  id           String          @id @default(cuid())
  type         FinanceItemType
  entityName   String
  code         String?
  rateTNA      Float?
  rateTEA      Float?
  rateTEM      Float?
  rateAdjust   String?
  term         Int?
  maturityDate DateTime?
  auctionDate  DateTime?
  currency     String          @default("ARS")
  notes        String?
  sourceUrl    String?
  active       Boolean         @default(true)
  updatedAt    DateTime        @updatedAt
  createdAt    DateTime        @default(now())

  @@index([type])
  @@index([active])
  @@map("finance_items")
}

model SavedPromo {
  id        String   @id @default(cuid())
  userId    String
  promoId   String
  createdAt DateTime @default(now())
  promo     Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promoId])
  @@map("saved_promos")
}

model Currency {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  symbol    String?
  createdAt DateTime @default(now())

  @@map("currencies")
}

model FinancialAccountType {
  id                String             @id @default(cuid())
  name              String             @unique
  description       String?
  createdAt         DateTime           @default(now())
  promoRequirements PromoRequirement[]

  @@map("financial_account_types")
}

model VtexPromoCache {
  site              String
  skuId             String
  segment           String   @default("generic")
  productId         String?
  productName       String?
  ean               String?
  listPrice         Float?
  salePrice         Float?
  promoCode         String
  effectiveDiscount Float
  category          String?
  updatedAt         DateTime @updatedAt

  @@id([site, skuId, segment])
  @@map("vtex_promo_cache")
}

model PromoClick {
  id        String   @id @default(cuid())
  promoId   String?
  url       String
  source    String   // promos | precios | detalle
  userId    String?
  createdAt DateTime @default(now())

  @@index([promoId])
  @@index([createdAt])
  @@map("promo_clicks")
}

model ScraperSchedule {
  id          String    @id @default(cuid())
  scraperId   String    @unique
  frequency   String    @default("manual") // manual | daily | weekly | monthly
  dayOfWeek   Int?      // 0-6 (para weekly)
  dayOfMonth  Int?      // 1-31 (para monthly)
  hour        Int       @default(6) // hora UTC
  active      Boolean   @default(true)
  nextRunAt   DateTime?
  updatedAt   DateTime  @updatedAt
  @@map("scraper_schedules")
}

model ScraperRun {
  id          String    @id @default(cuid())
  scraperId   String
  status      String    // running | success | error
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  found       Int?
  processed   Int?
  message     String?

  @@index([scraperId, startedAt])
  @@map("scraper_runs")
}

model bank_modo_codes {
  id         BigInt    @id @default(autoincrement())
  bankId     String
  modoCode   String    @unique
  created_at DateTime? @default(now()) @db.Timestamp(6)
  banks      Bank      @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([modoCode], map: "bank_modo_codes_code_idx")
}

model PromoCalendar {
  id            String   @id @default(cuid())
  date          DateTime
  label         String
  windowDays    Int      @default(5)
  pageSizeToday Int      @default(2000)
  pageSizeWeek  Int      @default(5000)
  createdAt     DateTime @default(now())

  @@index([date])
  @@map("promo_calendar")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum CardType {
  CREDIT
  DEBIT
  PREPAID
  ACCOUNT
}

enum CardTier {
  CLASSIC
  GOLD
  PLATINUM
  SIGNATURE
  BLACK
  INFINITE
  EMINENT
  SELECTA
}

enum DiscountType {
  PERCENTAGE_REINTEGRO
  PERCENTAGE_DESCUENTO
  BONIFICACION
  FIXED_AMOUNT
  NXM
  CUOTAS_SIN_INTERES
}

enum CapPeriod {
  PER_TRANSACTION
  DAILY
  WEEKLY
  MONTHLY
  TOTAL
}

enum CapTarget {
  USER
  CARD
  ACCOUNT
  TRANSACCION
}

enum PromoStatus {
  DRAFT
  ACTIVE
  EXPIRED
  PAUSED
}

enum PaymentChannel {
  ANY
  QR
  NFC
  TARJETA_FISICA
  TRANSFERENCIA
  DINERO_EN_CUENTA
}

enum AccountType {
  ANY
  HABERES
  JUBILADO
  ANSES
}

enum PostType {
  AVIVADA
  PROMO
  ERROR_PRECIO
  COMBO
  CONSULTA
}

enum FinanceItemType {
  PLAZO_FIJO
  CAUCION
  LECAP
  LECER
  BOPREAL
  ON
  FCI_MM
  DOLAR_TIPO
}

enum NotifType {
  CATEGORY
  COMMERCE
  PROXIMITY
  DIGEST
}

model SiteConfig {
  key   String @id
  value String

  @@map("site_config")
}
